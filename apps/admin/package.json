{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "supabase:login": "npx supabase login",
    "supabase:link": "npx supabase link",
    "supabase:db:reset": "npx supabase db query --linked --file supabase/reset.sql",
    "supabase:db:migrate": "npx supabase db push --linked --include-all",
    "supabase:db:seed": "npx supabase db query --linked --file supabase/seed.sql",
    "supabase:db:setup": "npm run supabase:db:reset && npm run supabase:db:migrate && npm run supabase:db:seed",
    "supabase:db:pull": "npx supabase db pull --linked",
    "supabase:db:diff": "npx supabase db diff --linked",
    "supabase:db:lint": "npx supabase db lint",
    "supabase:migration:list": "npx supabase migration list --linked",
    "supabase:migration:new": "npx supabase migration new",
    "supabase:types": "npx supabase gen types typescript --linked"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.11.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.78.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
