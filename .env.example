# Environment Variables — Snakitos AI
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVICE_ROLE_KEY

# ── Admin auth ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# Optional: auto-seeds first admin on first boot (remove after first login)
# ADMIN_BOOTSTRAP_EMAIL=your-admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=ChangeMe2024!

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY

# Optional: override embedding model (default: text-embedding-3-small)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector DB (Pinecone) ──────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_YOUR_PINECONE_KEY
PINECONE_INDEX=agent-index
# PINECONE_NAMESPACE=snakitos-admin

# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_YOUR_ACCESS_TOKEN
SHOPIFY_CLIENT_ID=YOUR_CLIENT_ID
SHOPIFY_CLIENT_SECRET=YOUR_CLIENT_SECRET

# ── Deprecated / not used by production code ─────────────────────────────────
# ADMIN_SECRET_KEY is not used — remove it from your .env entirely
