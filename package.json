    "axios": "^1.15.1",
    "dotenv": "^17.4.2",
    "openai": "^6.34.0",
    "yarn": "^1.22.22"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@vercel/node": "^5.7.12"
  }
}
