{
  "name": "agent",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "index.js",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/admin",
    "apps/chatbot"
  ],
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build:chatbot": "npm --prefix apps/chatbot run build",
    "build:admin": "npm --prefix apps/admin run build",
    "dev:chatbot": "npm --prefix apps/chatbot run dev",
    "dev:admin": "npm --prefix apps/admin run dev",
    "build:snakitos-rag-source": "node scripts/build-snakitos-rag-ingest-source.mjs",
    "ingest:json": "node scripts/ingest-json-to-pinecone.mjs",
    "ingest:capability": "node scripts/ingest-json-to-pinecone.mjs apps/chatbot/src/server/data/capability-knowledge.json",
    "ingest:snakitos-rag": "npm run build:snakitos-rag-source && node scripts/ingest-json-to-pinecone.mjs scripts/generated-snakitos-rag-ingest.json",
    "query:rag": "node scripts/query-pinecone-knowledge.mjs",
    "sync:snakitos": "node scripts/sync-snakitos-knowledge.mjs",
    "test:product-queries": "node scripts/test-product-queries.mjs",
    "test:product-expiry": "node scripts/test-product-expiry.mjs",
    "test:store-faq-safety": "node scripts/test-store-faq-safety.mjs",
    "test:support-claim-flow": "node scripts/test-support-claim-flow.mjs",
    "test:support-spicy-reset": "npx tsx scripts/test-support-spicy-reset.mjs",
    "test:halal-product-followup": "npx tsx scripts/test-halal-product-followup.mjs",
    "test:contextual-query-linking": "npx tsx scripts/test-contextual-query-linking.mjs",
    "test:brand-trust-flow": "npx tsx scripts/test-brand-trust-flow.mjs",
    "test:conversation-acceptance": "npx tsx scripts/test-conversation-acceptance.mjs",
    "test:phrase-coverage": "npx tsx scripts/test-phrase-coverage.mjs",
    "test:training-guide": "node scripts/test-training-guide-alignment.mjs",
    "start:chatbot": "npm --prefix apps/chatbot run start",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@pinecone-database/pinecone": "^7.2.0",
